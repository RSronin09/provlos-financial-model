{
  "installCommand": "cd logistics-model && npm install",
  "buildCommand": "cd logistics-model && npm run build",
  "outputDirectory": "logistics-model/dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "logistics-model/dist/public/**"
    }
  }
}
