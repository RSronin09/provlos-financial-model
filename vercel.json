{
  "installCommand": "cd logistics-model && npm install",
  "buildCommand": "cd logistics-model && npm run build && npx drizzle-kit push",
  "outputDirectory": "logistics-model/dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "logistics-model/dist/public/**,logistics-model/data.db"
    }
  }
}
